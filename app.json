{
  "expo": {
    "name": "SevaApp",
    "slug": "sevaApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "primaryColor": "#0B6E4F",
    "splash": {
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SevaApp uses your location once to find the emergency numbers and government services for your state and district."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "package": "com.sevaapp.mobile",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SevaApp uses your location once to find the emergency numbers and government services for your state and district."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3ed91e0a-e230-4505-ae19-bb27f5ab889d"
      }
    },
    "owner": "azyx"
  }
}
